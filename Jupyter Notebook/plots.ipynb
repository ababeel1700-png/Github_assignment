    "import plotly.express as px\n",
    "df = px.data.iris()\n",
    "fig = px.scatter(df, x=\"sepal_width\", y=\"sepal_length\", color=\"species\", marginal_y=\"violin\", \n",
    "                 marginal_x=\"box\", trendline=\"ols\", template= \"simple_white\")\n",
    "fig.show()"
